# ===========================================
# ISG Marketing Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Frontend URLs
VITE_FRONTEND_URL=https://app.isgmarketing.com
VITE_APP_URL=https://app.isgmarketing.com

# Google Maps (for geocoding in mass email targeting)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Supabase Edge Function Secrets
# Set via: supabase secrets set KEY=value
# ============================================

# App URLs (for OAuth callbacks, email links, CORS)
# APP_URL=https://app.isgmarketing.com
# FRONTEND_URL=https://app.isgmarketing.com

# SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_VALIDATION_KEY=your-sendgrid-validation-api-key
# SENDGRID_WEBHOOK_PUBLIC_KEY=your-webhook-verification-public-key
# SENDGRID_FORWARD_FROM=noreply@yourdomain.com

# Inbound Email Parsing
# REPLY_DOMAIN=reply.yourdomain.com

# OAuth - Google (for Gmail inbox injection)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Microsoft (for Outlook inbox injection)
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# MICROSOFT_TENANT_ID=common

# Token Encryption (32-byte hex key for AES-256-GCM)
# TOKEN_ENCRYPTION_KEY=your-64-char-hex-string

# Analytics Email Recipients
# ANALYTICS_FROM_EMAIL=analytics@yourdomain.com
# ANALYTICS_FROM_NAME=ISG Marketing Analytics
# ANALYTICS_RECIPIENT_EMAIL=admin@yourdomain.com
# ANALYTICS_RECIPIENT_NAME=Admin
